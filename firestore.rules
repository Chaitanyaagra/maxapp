rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers ----
    function isSignedIn() {
      return request.auth != null;
    }
    function staffDoc() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid));
    }
    function isStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }
    function isAdmin() {
      return isStaff() && staffDoc().data.role == 'admin';
    }
    // Ground staff (guard/housekeeping) OR an external vendor rep — either
    // way, a narrow role that can only ever see the specific defects
    // assigned to them, nothing else in the collection.
    function isNarrowStaff() {
      return isStaff() && (staffDoc().data.role == 'worker' || staffDoc().data.role == 'vendor');
    }
    // Admin or Supervisor — the two "broad access" roles, unchanged from
    // before the narrow roles existed.
    function isBroadStaff() {
      return isStaff() && !isNarrowStaff();
    }
    function bootstrapOpen() {
      return !exists(/databases/$(database)/documents/app_meta/bootstrap);
    }
    // A defect a worker has been assigned keeps a lightweight companion
    // doc in /assignments/{sameDocId} (the main defect record is one
    // opaque JSON string, so rules can't check assignedTo inside it
    // directly — this mirror is what makes that check possible).
    function isAssignedToMe(docId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/assignments/$(docId))
        && get(/databases/$(database)/documents/assignments/$(docId)).data.assignedToUid == request.auth.uid;
    }

    // ---- one-time setup lock ----
    // The app writes this the instant the very first Admin account is
    // created. While it doesn't exist, exactly one person can bootstrap
    // themselves in as Admin (see /staff/{uid} below); the moment it's
    // written, that path closes for everyone, permanently — there is no
    // rule that can ever delete or overwrite it.
    match /app_meta/bootstrap {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && bootstrapOpen() && request.resource.data.usedBy == request.auth.uid;
      allow update, delete: if false;
    }

    // ---- staff directory: who can sign in, and their role ----
    // This is what access to everything else is keyed on. A signed-in
    // Firebase Auth account with no matching document here can read/write
    // nothing except (for anonymous resident sessions) new complaints.
    match /staff/{uid} {
      allow read: if isStaff();
      allow create: if isSignedIn() && (
        // first-ever account, while bootstrap is open, becomes Admin
        (bootstrapOpen() && uid == request.auth.uid && request.resource.data.role == 'admin')
        // after that, only an existing Admin can add more staff
        || isAdmin()
      );
      allow update, delete: if isAdmin();
    }

    // ---- defect → worker assignment mirror ----
    // Kept in sync automatically by the app whenever a defect is saved.
    // Low-sensitivity (just defectId -> uid), so any signed-in staff
    // account can read the whole thing; only Admin/Supervisor can write
    // it (workers don't assign defects, they only resolve their own).
    match /assignments/{docId} {
      allow read: if isStaff();
      allow write: if isBroadStaff();
    }

    // ---- all operational app data (inspections, defects, resident
    // complaints, tasks, vendors, audit log, members roster, settings) ----
    // Everything the app stores lives in this one collection as
    // {value: "<json string>", updatedAt}, so rules can't validate
    // individual fields inside that JSON — only where a write can land,
    // its overall size, and whether it's a brand-new document.
    match /mhm_records/{docId} {
      // Admin / Supervisor — full access, same as before the worker role.
      allow read, update, delete: if isBroadStaff();

      // Ground staff / vendor — only a defect they're specifically
      // assigned to, and only to update it (e.g. mark resolved), never
      // delete or read anything else in this collection.
      allow read: if isNarrowStaff() && docId.matches('defect:.*') && isAssignedToMe(docId);
      allow update: if isNarrowStaff() && docId.matches('defect:.*') && isAssignedToMe(docId);

      // Public resident-complaint link (?resident=1): create-only, and
      // only brand-new "defect:*" documents — matches exactly what that
      // page does today (submit a complaint) and nothing else. No read,
      // no list, no update, no delete for this identity, ever.
      allow create: if isSignedIn()
                    && !isStaff()
                    && docId.matches('defect:.*')
                    && request.resource.size() < 900000;
    }
  }
}

